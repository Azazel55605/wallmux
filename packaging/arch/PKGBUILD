# Maintainer: Wallmux contributors
pkgname=wallmux
pkgver=0.2.3
pkgrel=1
pkgdesc="Hyprland-first wallpaper manager and backend orchestrator"
arch=("any")
url="https://github.com/wallmux/wallmux"
license=("MIT")
depends=(
  "hyprland"
  "python"
  "python-platformdirs"
  "python-pillow"
  "python-pyside6"
  "python-python-magic"
  "python-tomli-w"
)
makedepends=(
  "python-build"
  "python-hatchling"
  "python-installer"
)
optdepends=(
  "awww: default image and GIF wallpaper backend"
  "swww: optional image and GIF wallpaper backend"
  "hyprpaper: optional static image wallpaper backend"
  "mpvpaper: default video wallpaper backend"
  "gslapper: optional video/GIF wallpaper backend"
  "ffmpeg: video thumbnail extraction"
  "libnotify: notify-send desktop notifications"
  "python-pywal: optional color hook integration"
  "matugen: optional color hook integration"
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/wallmux/wallmux/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=("SKIP")

build() {
  cd "$pkgname-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "$pkgname-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 packaging/applications/wallmux-gui.desktop \
    "$pkgdir/usr/share/applications/wallmux-gui.desktop"
  install -Dm644 packaging/icons/wallmux.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/wallmux.svg"
  install -Dm644 packaging/icons/wallmux.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/wallmux-gui.svg"
  install -Dm644 packaging/systemd/wallmux.service \
    "$pkgdir/usr/lib/systemd/user/wallmux.service"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
